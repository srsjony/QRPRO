{
  "expo": {
    "name": "Restromate",
    "slug": "restromate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080807"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qrmenupro.restaurant"
    },
    "android": {
      "package": "com.qrmenupro.restaurant",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080807"
      },
      "permissions": [
        "INTERNET",
        "CAMERA",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "616bd4bd-341a-4f92-8ef9-05ced2d88feb"
      }
    }
  }
}
